<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
	version="4.0">

	<!-- 認証 -->
	<filter>
		<filter-name>DeviceDistinctionFilter</filter-name>
		<filter-class>filter.DeviceDistinctionFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>DeviceDistinctionFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	<!-- ログイン認証 -->
	<filter>
		<filter-name>AdminAuthenticationFilter</filter-name>
		<filter-class>filter.AdminAuthenticationFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>AdminAuthenticationFilter</filter-name>
		<url-pattern>/manage/*</url-pattern>
	</filter-mapping>

	<!-- ページのキャッシュ無効化（HTMLナビゲーション向け） -->
	<filter>
		<filter-name>NoCacheFilter</filter-name>
		<filter-class>filter.NoCacheFilter</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>NoCacheFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

</web-app>
